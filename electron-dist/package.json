{
  "name": "focus-app",
  "version": "1.0.0",
  "description": "Focus 专注与学习分析桌面应用",
  "main": "main.js",
  "productName": "Focus",
  "author": "AsterLane",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack:mac": "electron-builder --mac dmg zip",
    "pack:win": "electron-builder --win portable zip",
    "pack:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.asterlane.focus",
    "productName": "Focus",
    "files": [
      "index.html",
      "logo-login.svg",
      "main.js",
      "build/**/*"
    ],
    "extraFiles": [
      {
        "from": "focus.config.json",
        "to": "focus.config.json"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "asar": true,
    "artifactName": "Focus-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12"
  }
}
